# FPL Report — environment variables template
# Copy this file to .env for local development
# Never commit .env to the repository

# Your personal FPL team ID (optional — used for the League & My Team page)
# Find it in the URL when you visit your team page on fantasy.premierleague.com
FPL_TEAM_ID=

# Your FPL mini-league ID (optional)
FPL_LEAGUE_ID=
